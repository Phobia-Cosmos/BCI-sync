# Local datasets are large and should not be synchronized through Git.
data/

# Archives and downloaded bundles.
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.rar
*.download-failed

# Nested repository metadata from downloaded codebases.
**/.git/
code/**/.git/

# Dataset copies inside cloned code repositories.
code/**/data/
code/**/datasets/

# Common generated/cache files.
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.DS_Store
Thumbs.db

# Local logs and temporary outputs.
*.log
*.tmp
*.temp
